<?xml version="1.0" encoding="utf-8"?>
<layout>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="12dp">

    <ImageView
        android:id="@+id/rank_image"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_star"
        app:tint="@color/ludo_star_tint" />

    <TextView
        android:id="@+id/rank_text"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="1st Place"
        android:textColor="@color/text_on_background"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/player_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_pawn_green" />

    <TextView
        android:id="@+id/player_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:text="Player Green"
        android:textColor="@color/text_on_background"
        android:textSize="18sp" />

</LinearLayout>
</layout>