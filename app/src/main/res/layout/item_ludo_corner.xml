<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <View
        android:id="@+id/inner_pane"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.75" />

    <View
        android:id="@+id/dot1"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/ic_star"
        android:backgroundTint="#000000"
        app:layout_constraintBottom_toTopOf="@+id/dot3"
        app:layout_constraintEnd_toStartOf="@+id/dot2"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="@+id/inner_pane"
        app:layout_constraintTop_toTopOf="@+id/inner_pane" />

    <View
        android:id="@+id/dot2"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/ic_star"
        android:backgroundTint="#000000"
        app:layout_constraintBottom_toTopOf="@+id/dot4"
        app:layout_constraintEnd_toEndOf="@+id/inner_pane"
        app:layout_constraintStart_toEndOf="@+id/dot1"
        app:layout_constraintTop_toTopOf="@+id/inner_pane" />

    <View
        android:id="@+id/dot3"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/ic_star"
        android:backgroundTint="#000000"
        app:layout_constraintBottom_toBottomOf="@+id/inner_pane"
        app:layout_constraintEnd_toStartOf="@+id/dot4"
        app:layout_constraintStart_toStartOf="@+id/inner_pane"
        app:layout_constraintTop_toBottomOf="@+id/dot1" />

    <View
        android:id="@+id/dot4"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/ic_star"
        android:backgroundTint="#000000"
        app:layout_constraintBottom_toBottomOf="@+id/inner_pane"
        app:layout_constraintEnd_toEndOf="@+id/inner_pane"
        app:layout_constraintStart_toEndOf="@+id/dot3"
        app:layout_constraintTop_toBottomOf="@+id/dot2" />

</androidx.constraintlayout.widget.ConstraintLayout>
